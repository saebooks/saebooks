# SAE Books — local development configuration
# Copy to .env and adjust. Do NOT commit .env.

# Database
POSTGRES_USER=saebooks
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=saebooks
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://saebooks:change-me-local-only@db:5432/saebooks

# App
SAEBOOKS_EDITION=community
SAEBOOKS_LOG_LEVEL=INFO
SAEBOOKS_BIND_HOST=127.0.0.1
SAEBOOKS_BIND_PORT=8042

# Bootstrap admins — usernames in this list are auto-promoted to
# ``admin`` on first upsert + re-promoted if somehow demoted. Solves
# the chicken-and-egg of "first user on a fresh install needs admin
# to promote others". Comma-separated; match the Authentik Remote-User
# value exactly. Leave empty for new installs that don't sit behind SSO
# yet (the dev-override env vars SAEBOOKS_DEV_USER / SAEBOOKS_DEV_ROLE
# cover that case).
SAEBOOKS_BOOTSTRAP_ADMINS=

# Phase 0 API bearer token — the /api/v1/* routers require
# ``Authorization: Bearer <this value>``. Leave empty and the server
# will log an ephemeral random token at boot (good enough for local
# development; terrible for anything else). Real JWT wiring against
# portal.sauer.com.au lands in Phase 1 cycle 3.
SAEBOOKS_DEV_API_TOKEN=

# Seed — default company (Richard's books)
SEED_COMPANY_NAME=Sauer Pty Ltd ATF Saueesti Trust
SEED_COMPANY_LEGAL_NAME=Sauer Pty Ltd
SEED_COMPANY_TRADING_NAME=SAE Engineering
SEED_COMPANY_ABN=87744586592
SEED_COMPANY_ACN=683275756
SEED_COMPANY_BASE_CURRENCY=AUD
SEED_COMPANY_FIN_YEAR_START_MONTH=7

# SAE Books — local development configuration
# Copy to .env and adjust. Do NOT commit .env.

# Database
POSTGRES_USER=saebooks
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=saebooks
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://saebooks:change-me-local-only@db:5432/saebooks

# App
SAEBOOKS_EDITION=community
SAEBOOKS_LOG_LEVEL=INFO
SAEBOOKS_BIND_HOST=127.0.0.1
SAEBOOKS_BIND_PORT=8042

# Bootstrap admins — usernames in this list are auto-promoted to
# ``admin`` on first upsert + re-promoted if somehow demoted. Solves
# the chicken-and-egg of "first user on a fresh install needs admin
# to promote others". Comma-separated; match the username (derived
# from the verified email) exactly. Leave empty for new installs;
# the dev-override env vars SAEBOOKS_DEV_USER / SAEBOOKS_DEV_ROLE
# cover that case.
SAEBOOKS_BOOTSTRAP_ADMINS=

# SQL tool — sandboxed read-only Postgres role (Cat-C admin).
# Migration 0087 creates ``saebooks_sql_ro`` with ``pg_read_all_data``
# and REVOKEs on ``pg_read_server_files`` / ``lo_export`` / friends.
# /api/v1/admin/sql/execute uses this role for every plain SELECT.
# Generate with: openssl rand -base64 24 | tr -d '/+=' | head -c 32
# Required for migration 0087 to apply (DDL refuses an empty value).
SAEBOOKS_SQL_RO_PASSWORD=

# Phase 0 API bearer token — the /api/v1/* routers require
# ``Authorization: Bearer <this value>``. Leave empty and the server
# will log an ephemeral random token at boot (good enough for local
# development; terrible for anything else). Point real JWT wiring at
# your own licence portal.
SAEBOOKS_DEV_API_TOKEN=

# Seed — default company (edit to your own entity)
SEED_COMPANY_NAME=Example Pty Ltd
SEED_COMPANY_LEGAL_NAME=Example Pty Ltd
SEED_COMPANY_TRADING_NAME=Example Trading
SEED_COMPANY_ABN=51824753556
SEED_COMPANY_ACN=
SEED_COMPANY_BASE_CURRENCY=AUD
SEED_COMPANY_FIN_YEAR_START_MONTH=7

#!/bin/bash
# Sync the SAE Books MCP env vars from the canonical secrets file into
# the systemd --user environment.d mirror, then reload.
#
# Run this after rotating SAEBOOKS_CC_TOKEN (or any other SAEBOOKS_CC_*
# value) in ~/.claude/secrets/saebooks-claude-code.env. The mirror at
# ~/.config/environment.d/50-saebooks-claude-code.conf is what systemd
# --user units pick up at startup.
#
# Usage:
#   saebooks-token-sync                # sync + reload + summary
#   saebooks-token-sync --check        # report drift only, exit 1 if different
#   saebooks-token-sync --no-reload    # write mirror but skip daemon-reload
#
# Exits non-zero on any error so it's safe to chain in pre-commit /
# rotation scripts.

set -euo pipefail

CANONICAL="${HOME}/.claude/secrets/saebooks-claude-code.env"
MIRROR="${HOME}/.config/environment.d/50-saebooks-claude-code.conf"
HEADER_FILE="$(mktemp --tmpdir saebooks-sync-header-XXXXXX)"
NEW_MIRROR="$(mktemp --tmpdir saebooks-sync-mirror-XXXXXX)"
trap 'rm -f "$HEADER_FILE" "$NEW_MIRROR"' EXIT

CHECK_ONLY=0
RELOAD=1
for arg in "$@"; do
    case "$arg" in
        --check)     CHECK_ONLY=1 ;;
        --no-reload) RELOAD=0 ;;
        -h|--help)
            sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *)
            echo "saebooks-token-sync: unknown arg '$arg'" >&2
            exit 2
            ;;
    esac
done

if [ ! -r "$CANONICAL" ]; then
    echo "saebooks-token-sync: $CANONICAL missing or unreadable" >&2
    exit 1
fi

# The mirror keeps its own header comments — preserve them verbatim and
# only replace the KEY=value section.
cat >"$HEADER_FILE" <<'EOF'
# systemd --user environment for SAE Books MCP token.
#
# Read at startup of every `systemd --user` unit. Lets cron-via-systemd
# timers, scheduled-agent units, and any other user-mode service see
# ${SAEBOOKS_CC_TOKEN} when they spawn claude or call the SAE Books API.
#
# Format: KEY=value, one per line. No shell expansion, no quoting needed.
# Mirror of (canonical) ~/.claude/secrets/saebooks-claude-code.env.
#
# Generated by ~/bin/saebooks-token-sync — do not hand-edit. Edit the
# canonical file at ~/.claude/secrets/saebooks-claude-code.env then run
# `saebooks-token-sync` to refresh this file + reload systemd.

EOF

# Extract just the KEY=value lines from canonical (skip comments + blanks)
# and append to the mirror. grep -E '^[A-Z][A-Z0-9_]*=' is restrictive
# enough to avoid sourcing arbitrary shell from a hostile canonical.
{
    cat "$HEADER_FILE"
    grep -E '^[A-Z][A-Z0-9_]*=' "$CANONICAL"
} >"$NEW_MIRROR"

if [ "$CHECK_ONLY" -eq 1 ]; then
    if [ ! -f "$MIRROR" ]; then
        echo "saebooks-token-sync: mirror does not exist yet — would create $MIRROR"
        exit 1
    fi
    if diff -q "$NEW_MIRROR" "$MIRROR" >/dev/null 2>&1; then
        echo "saebooks-token-sync: in sync"
        exit 0
    else
        echo "saebooks-token-sync: DRIFT detected — canonical → mirror:"
        diff -u "$MIRROR" "$NEW_MIRROR" || true
        exit 1
    fi
fi

# Write mirror with restrictive perms (mode 600).
install -D -m 600 "$NEW_MIRROR" "$MIRROR"

# How many KEY=value lines did we sync?
count=$(grep -cE '^[A-Z][A-Z0-9_]*=' "$MIRROR" || true)
echo "saebooks-token-sync: wrote $MIRROR ($count vars)"

if [ "$RELOAD" -eq 1 ]; then
    if systemctl --user is-system-running >/dev/null 2>&1 \
       || systemctl --user --no-pager status >/dev/null 2>&1; then
        systemctl --user daemon-reload
        # import-environment is for the launcher's current env — useful
        # so any already-running --user units that re-fork see the new
        # value. Harmless when no env to import.
        systemctl --user import-environment SAEBOOKS_CC_TOKEN SAEBOOKS_CC_USER_ID \
            SAEBOOKS_CC_COMPANY_ID SAEBOOKS_CC_TENANT_ID SAEBOOKS_RICHARD_USER_ID \
            2>/dev/null || true
        echo "saebooks-token-sync: systemd --user reloaded"
    else
        echo "saebooks-token-sync: systemd --user not available — skipped reload"
    fi
fi

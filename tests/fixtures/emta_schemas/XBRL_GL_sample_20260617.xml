	<!-- Contexts, is mandatory. According to the XBRL specification -->
	<xbrli:context id="now">
<!-- The following block displays the registry code of the person (for whom the data are being transmitted). Must match the value shown at 
gl-cor:uniqueID and in the block gl-bus:organizationIdentifiers -->
        <xbrli:entity>
            <!-- Scheme specifies the code. Allowed code specifications from the list ORGANIZATIONDESCRIPTION_enum, excl. TOIMLA_KOOD -->
            <xbrli:identifier scheme="ARIREGISTRIKOOD">10001234</xbrli:identifier>
        </xbrli:entity>
		<!-- Date of file creation -->
		<xbrli:period>
			<xbrli:instant>2027-02-08</xbrli:instant>
		</xbrli:period>
	</xbrli:context>
	<!-- Both currency and other agreed-upon units of measurement are considered as units of measurement -->
	<xbrli:unit id="EUR">
		<xbrli:measure>iso4217:EUR</xbrli:measure>
	</xbrli:unit>
	<xbrli:unit id="pureRef">
		<xbrli:measure>pure</xbrli:measure>
	</xbrli:unit>
	<xbrli:unit id="NotUsed">

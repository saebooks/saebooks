					<xs:documentation>Calculated: Proportion of taxed distribution of equity compared to total equity distributed
          </xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:decimal">
						<xs:totalDigits value="13"/>
						<xs:fractionDigits value="9"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="tsd_Inf1_1List" minOccurs="0">
				<xs:complexType>
					<xs:sequence>
						<xs:element name="tsd_Inf1_1" type="tsdInf11" maxOccurs="unbounded"/>
					</xs:sequence>
				</xs:complexType>
			</xs:element>
		</xs:all>
	</xs:complexType>
	<xs:complexType name="tsdInf11">
		<xs:all>
			<xs:element name="c13000_EstRegkood" minOccurs="0">

					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="c13070_VmMaksustSumma" minOccurs="0">
				<xs:annotation>
					<xs:documentation>Calculated: incl. taxed distributions of equity</xs:documentation>
				</xs:annotation>
				<xs:simpleType>
					<xs:restriction base="xs:decimal">
						<xs:totalDigits value="22"/>
						<xs:fractionDigits value="2"/>
					</xs:restriction>
				</xs:simpleType>
			</xs:element>
			<xs:element name="c13072_MvtSumma" minOccurs="0">
				<xs:annotation>

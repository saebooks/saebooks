# SAE Books — Community Edition bundle — example environment.
#
# Copy to `.env` in this directory and fill in the REQUIRED values.
# `docker compose up` is fail-closed: it aborts if a REQUIRED token is
# missing rather than starting an unauthenticated service.
#
# Generate strong random tokens, e.g.:  openssl rand -hex 32

# ---- Database -------------------------------------------------------
POSTGRES_USER=saebooks
POSTGRES_DB=saebooks
# REQUIRED — database password. The engine's DATABASE_URL is assembled
# from these three values inside docker-compose.yml (never hand-write a
# credential-in-URL here).
POSTGRES_PASSWORD=

# ---- Shared inter-container secrets (REQUIRED, fail-closed) ----------
# Must be IDENTICAL for `api` and `latex-api`.
RENDER_SERVICE_TOKEN=
# Gates the engine's /internal/* module hand-off endpoints.
INTERNAL_API_TOKEN=
# Signs the web UI's browser sessions.
SAEBOOKS_WEB_SECRET_KEY=

# ---- Engine (optional) ----------------------------------------------
SAEBOOKS_EDITION=community
SAEBOOKS_LOG_LEVEL=INFO
SAEBOOKS_LOG_JSON=false
# Field-level encryption key for stored secrets (bank tokens, etc).
SAEBOOKS_FIELD_ENCRYPTION_KEY=

# ---- Outbound mail (optional — blank disables) ----------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=books@example.com

# ---- First-boot company seed (optional) -----------------------------
SEED_COMPANY_NAME=
SEED_COMPANY_LEGAL_NAME=
SEED_COMPANY_ABN=

# ---- Optional modules (only if you uncomment them in compose) -------
# PREACCOUNTING_TOKEN=

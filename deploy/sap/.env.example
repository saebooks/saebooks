# SAE Books SAP bundle — environment variables
# Copy this file to .env and fill in the required values before running.
#
# Required — must be set before first launch
# ------------------------------------------

# Postgres password for the saebooks DB user. Use a strong random value.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=change-me-strong-random-value

# Secret key for the web frontend's signed session cookies. Must be 32+ bytes.
# Generate one: python3 -c "import secrets; print(secrets.token_hex(32))"
SAEBOOKS_WEB_SECRET_KEY=change-me-strong-random-hex

# Optional — sensible defaults are set in docker-compose.yml
# -----------------------------------------------------------

# Postgres connection (defaults match the db service above)
POSTGRES_USER=saebooks
POSTGRES_DB=saebooks

# SAE Books edition: community | offline | business | pro | enterprise
# "community" is free, works offline, and is the default for self-hosted
# installs. Higher editions require a licence JWT from
# portal.saebooks.com.au.
SAEBOOKS_EDITION=community

# Log level: DEBUG | INFO | WARNING | ERROR
SAEBOOKS_LOG_LEVEL=INFO
SAEBOOKS_WEB_LOG_LEVEL=INFO

# Structured JSON logs (useful if feeding into Loki / Elastic / Datadog)
SAEBOOKS_LOG_JSON=false

# Sentry error tracking (leave empty to disable)
SENTRY_DSN=

# Seed company details (used only on first-run DB initialisation)
SEED_COMPANY_NAME=
SEED_COMPANY_LEGAL_NAME=
SEED_COMPANY_ABN=

# Field-level encryption key for sensitive stored values (SISS credentials, etc.)
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to disable field encryption (not recommended for production).
SAEBOOKS_FIELD_ENCRYPTION_KEY=

# SMTP for outbound email (invoice delivery, etc.)
# Leave SMTP_HOST empty to write emails to /app/mail-outbox instead (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=books@example.com

# Admin account (used by first-run setup wizard, if implemented)
SAEBOOKS_ADMIN_EMAIL=admin@example.com
